{
  "name": "@reserve-protocol/dtf-rebalance-lib",
  "version": "3.3.1",
  "description": "Rebalancing library for DTFs in typescript",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "docs",
    "LICENSE.md",
    "README.md"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "compile": "hardhat compile",
    "compile:dtf-artifacts": "FOUNDRY_PROFILE=reserve-index-dtf forge build --skip script --skip test",
    "build": "npm run clean && tsc --project tsconfig.build.json",
    "build:internal-tools": "npm run build -w @reserve-protocol/dtf-rebalance-tools",
    "build:tools": "npm run build:internal-tools",
    "prepublishOnly": "npm run build",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test --require ts-node/register test/**/unit.test.ts",
    "pretest:e2e": "npm run compile:dtf-artifacts",
    "test:e2e": "hardhat test packages/tools/test/*.test.ts --bail"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "typescript",
    "npm",
    "package"
  ],
  "author": "Reserve Team",
  "license": "BlueOak-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reserve-protocol/dtf-rebalance-lib.git"
  },
  "bugs": {
    "url": "https://github.com/reserve-protocol/dtf-rebalance-lib/issues"
  },
  "homepage": "https://github.com/reserve-protocol/dtf-rebalance-lib#readme",
  "peerDependencies": {
    "decimal.js-light": "^2.5.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.3.0",
    "@reserve-protocol/reserve-index-dtf": "github:reserve-protocol/reserve-index-dtf#e3b66635f13f3059e1762255882d4fc21c4e03df",
    "@types/node": "^24.0.0",
    "dotenv": "^16.5.0",
    "hardhat": "^2.24.1",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
